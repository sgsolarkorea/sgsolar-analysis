{
  "name": "sgsolar-analysis",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:kepco-contacts": "node scripts/build-kepco-office-contacts.mjs",
    "build:kepco-registry": "node scripts/build-kepco-office-registry.mjs",
    "build:korea-regions": "node scripts/build-korea-region-registry.mjs",
    "build:regulatory-db": "node scripts/build-korea-region-registry.mjs && node scripts/build-regulatory-db.mjs",
    "collect:regulation-sources": "node scripts/collect-regulation-sources.mjs --all",
    "collect:regulation-sources:priority": "node scripts/collect-regulation-sources.mjs --priority",
    "parse:regulation-ordinances": "node scripts/parse-regulation-ordinances.mjs --all",
    "parse:regulation-ordinances:priority": "node scripts/parse-regulation-ordinances.mjs --priority",
    "parse:regulation-ordinances:metro": "node scripts/parse-regulation-ordinances-metro.mjs --with-appendices",
    "parse:regulation-appendices": "node scripts/parse-regulation-appendices.mjs --all",
    "parse:regulation-appendices:priority": "node scripts/parse-regulation-appendices.mjs --priority",
    "validate:regulatory-db": "node scripts/validate-regulatory-db.mjs",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@sparticuz/chromium": "^149.0.0",
    "@upstash/redis": "^1.38.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.0",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^25.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@ohah/hwpjs": "^0.1.0-rc.10",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "kordoc": "^3.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
