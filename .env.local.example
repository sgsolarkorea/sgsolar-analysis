# 카카오 Developers — REST API 키 (서버 전용, 주소검색)
# https://developers.kakao.com/ → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# 카카오 Developers — JavaScript 키 (클라이언트, 지도 표시)
# https://developers.kakao.com/ → 내 애플리케이션 → 앱 키 → JavaScript 키
# 플랫폼에 http://localhost:3000 등록 필요
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key_here

# VWorld Open API — 인증키 (서버 전용, 토지/PNU 조회)
# https://www.vworld.kr/v4po_main.do → 오픈API → 인증키 발급
# API 신청: 2D데이터(연속지적도) + 국가중점데이터(토지특성속성)
VWORLD_API_KEY=your_vworld_api_key_here
# VWorld 키 발급 시 등록한 도메인 (선택, 기본 localhost:3000)
VWORLD_API_DOMAIN=localhost:3000

# 상담신청 이메일 — Production: Resend 우선, 로컬/백업: Naver SMTP
# https://resend.com — API Keys에서 RESEND_API_KEY 발급
# 발신 도메인 인증 후 RESEND_FROM_EMAIL 설정 (예: SG SOLAR <noreply@sgsolar.co.kr>)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=SG SOLAR <onboarding@resend.dev>
CONSULTATION_RECEIVER_EMAIL=sgsolarkorea@naver.com

# Naver SMTP (Resend 미설정·실패 시 fallback, 로컬 개발용)
SMTP_HOST=smtp.naver.com
SMTP_PORT=587
SMTP_USER=your_naver_email@naver.com
SMTP_PASS=your_naver_app_password

# 공공데이터포털 — 건축HUB 건축물대장정보 서비스 (서버 전용)
# https://www.data.go.kr/data/15134735/openapi.do
# SMP/REC 시장단가 JSON (Cloudflare Workers 또는 자동화 JSON URL)
# 미설정 또는 실패 시 src/data/solarConfig.ts fallback 사용
MARKET_DATA_URL=https://your-worker.example.com/market_data.json

# 입지검토 조회 이력 · 조례 학습 — Production: Upstash Redis (동일 인스턴스)
# 1) Vercel Dashboard → 프로젝트 → Storage → Create Database → Upstash Redis
#    또는 Integrations → Upstash → Upstash for Redis 설치 후 프로젝트 연결
# 2) 연결 시 아래 변수가 자동 주입됩니다 (둘 중 한 세트)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# CLI 예: npx vercel integration add upstash -e production
# Redis 미설정 시 결과 페이지는 정상 동작하며, 이력·조례 저장만 비활성화됩니다.

# 관리자 페이지 (/admin/search-history, /admin/ordinances) 접근 비밀번호
ADMIN_PASSWORD=your_secure_admin_password

# 조례 학습 시스템 — 로컬 JSON 저장 (Production에서는 Upstash Redis 사용)
# ORDINANCE_JSON_STORAGE=true

# AI 조례 초안 생성 (선택, 미설정 시 템플릿 기반 초안)
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_ORDINANCE_MODEL=gpt-4o-mini

# 로컬 개발 시 JSON 파일 저장 (Production에서는 사용하지 않음)
# SEARCH_HISTORY_JSON_STORAGE=true
